#!/usr/bin/env bash
set -euo pipefail

user_bin="$HOME/.local/bin"
mkdir -p "$user_bin"

cat > "$user_bin/nvim" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/nvim" "$@"
SH

cat > "$user_bin/nvim-dev" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/nvim-dev" "$@"
SH

cat > "$user_bin/opencode" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/opencode" "$@"
SH

chmod +x "$user_bin/nvim" "$user_bin/nvim-dev" "$user_bin/opencode"

opencode_config="$HOME/.config/opencode"
mkdir -p "$opencode_config/themes"
install -m 0644 "$HOME/.config/nvim/opencode/tui.json" "$opencode_config/tui.json"
install -m 0644 "$HOME/.config/nvim/opencode/themes/gruvbox-soft-dark.json" "$opencode_config/themes/gruvbox-soft-dark.json"

printf 'installed nvim wrappers to %s\n' "$user_bin"
printf 'installed opencode theme to %s\n' "$opencode_config"
