#!/usr/bin/env bash
set -euo pipefail

target="${1:-.}"

if [[ -t 2 && "${NO_COLOR:-}" == "" ]]; then
  c_reset=$'\033[0m'
  c_dim=$'\033[2m'
  c_red=$'\033[31m'
  c_green=$'\033[32m'
  c_yellow=$'\033[33m'
  c_blue=$'\033[34m'
  c_magenta=$'\033[35m'
  c_cyan=$'\033[36m'
  c_bold=$'\033[1m'
else
  c_reset= c_dim= c_red= c_green= c_yellow= c_blue= c_magenta= c_cyan= c_bold=
fi

log() { printf '%b\n' "$*" >&2; }
banner() { log "${c_cyan}${c_bold}╭─ nvim-dev${c_reset} ${c_dim}containerized editor uplink${c_reset}"; }
step() { log "${c_blue}▸${c_reset} ${c_bold}$1${c_reset}${2:+ ${c_dim}$2${c_reset}}"; }
ok() { log "${c_green}✓${c_reset} $1${2:+ ${c_dim}$2${c_reset}}"; }
info() { log "${c_magenta}λ${c_reset} $1${2:+ ${c_dim}$2${c_reset}}"; }
die() { log "${c_red}✗${c_reset} ${c_bold}nvim-dev:${c_reset} $*"; exit 1; }

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

real_nvim() {
  if [[ -n "${NVIM_REAL_BIN:-}" && -x "${NVIM_REAL_BIN:-}" ]]; then
    printf '%s\n' "$NVIM_REAL_BIN"
    return 0
  fi

  local candidate
  IFS=: read -ra path_entries <<< "$PATH"
  for candidate_dir in "${path_entries[@]}"; do
    candidate="$candidate_dir/nvim"
    if [[ -x "$candidate" && "$candidate" != "$HOME/.local/bin/nvim" && "$candidate" != "$HOME/.config/nvim/bin/nvim" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

install_host_wrappers() {
  local user_bin="$HOME/.local/bin"
  mkdir -p "$user_bin"

  cat > "$user_bin/nvim-dev" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/nvim-dev" "$@"
SH
  chmod +x "$user_bin/nvim-dev"

  cat > "$user_bin/nvim" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/nvim" "$@"
SH
  chmod +x "$user_bin/nvim"

  cat > "$user_bin/opencode" <<'SH'
#!/usr/bin/env bash
exec "$HOME/.config/nvim/bin/opencode" "$@"
SH
  chmod +x "$user_bin/opencode"
}

devcontainer_cmd() {
  if command -v devcontainer >/dev/null 2>&1; then
    printf 'devcontainer\n'
  elif command -v npx >/dev/null 2>&1; then
    printf 'npx -y @devcontainers/cli\n'
  else
    die "missing devcontainer CLI; install with: npm install -g @devcontainers/cli"
  fi
}

quote() {
  printf '%q' "$1"
}

nvim_remote_expr() {
  local addr="$1" expr="$2"
  local nvim_bin
  nvim_bin="$(real_nvim)" || die "real nvim binary not found"
  if command -v timeout >/dev/null 2>&1; then
    timeout 2s "$nvim_bin" --server "$addr" --remote-expr "$expr" >/dev/null 2>&1
  else
    "$nvim_bin" --server "$addr" --remote-expr "$expr" >/dev/null 2>&1
  fi
}

project_root() {
  local dir
  dir="$(cd "$target" 2>/dev/null && pwd -P)" || die "not a directory: $target"
  while [[ "$dir" != / ]]; do
    if [[ -f "$dir/.devcontainer/devcontainer.json" || -f "$dir/devcontainer.json" || -d "$dir/.git" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  cd "$target" && pwd -P
}

has_devcontainer() {
  [[ -f "$root/.devcontainer/devcontainer.json" || -f "$root/devcontainer.json" ]]
}

devcontainer_json() {
  if [[ -f "$root/.devcontainer/devcontainer.json" ]]; then
    printf '%s\n' "$root/.devcontainer/devcontainer.json"
  else
    printf '%s\n' "$root/devcontainer.json"
  fi
}

devcontainer_json_value() {
  local key="$1"
  python3 - "$(devcontainer_json)" "$key" <<'PY'
import json, sys
with open(sys.argv[1], "r", encoding="utf-8") as f:
    value = json.load(f).get(sys.argv[2], "")
if isinstance(value, str):
    print(value)
PY
}

container_workspace() {
  local container="$1"
  local root_name json_ws label_ws
  root_name="$(basename "$root")"

  json_ws="$(devcontainer_json_value workspaceFolder || true)"
  if [[ -n "$json_ws" ]]; then
    printf '%s\n' "$json_ws"
    return 0
  fi

  label_ws="$(docker inspect -f '{{ index .Config.Labels "devcontainer.workspace_folder" }}' "$container" 2>/dev/null || true)"
  if [[ -n "$label_ws" && "$label_ws" != "<no value>" ]]; then
    printf '%s\n' "$label_ws"
    return 0
  fi

  local mount_dest
  mount_dest="$(docker inspect -f '{{ range .Mounts }}{{ if eq .Source "'"$root"'" }}{{ .Destination }}{{ "\n" }}{{ end }}{{ end }}' "$container" 2>/dev/null | head -n1 || true)"
  if [[ -n "$mount_dest" ]]; then
    printf '%s\n' "$mount_dest"
    return 0
  fi

  printf '/workspaces/%s\n' "$root_name"
}

container_host() {
  local container="$1"
  local network_json
  network_json="$(docker inspect -f '{{json .NetworkSettings.Networks}}' "$container")"
  if printf '%s' "$network_json" | grep -q '"host"'; then
    printf '127.0.0.1\n'
    return 0
  fi
  local ip
  ip="$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$container")"
  [[ -n "$ip" ]] || die "could not determine container IP for $container"
  printf '%s\n' "$ip"
}

choose_container() {
  local containers
  containers="${1:-$(docker ps --format '{{.Names}}\t{{.Image}}\t{{.Status}}')}"
  [[ -n "$containers" ]] || die "no containers"

  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$containers" | fzf --prompt='Attach container> ' | cut -f1
    return 0
  fi

  log "Matching containers:"
  local i=0 names=()
  while IFS=$'\t' read -r name image status; do
    i=$((i + 1))
    names+=("$name")
    log "  $i) $name  $image  $status"
  done <<< "$containers"
  printf 'Select container: ' >&2
  local choice
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid selection"
  printf '%s\n' "${names[$((choice - 1))]}"
}

project_containers() {
  local root_name image_name
  root_name="$(basename "$root")"
  image_name="vsc-${root_name//-/_}"

  docker ps -a --format '{{.Names}}\t{{.Image}}\t{{.Status}}' | while IFS=$'\t' read -r name image status; do
    if docker inspect -f '{{ range .Mounts }}{{ .Source }} {{ end }}' "$name" 2>/dev/null | grep -Fq "$root"; then
      printf '%s\t%s\t%s\n' "$name" "$image" "$status"
    elif [[ "$image" == "$image_name"* ]]; then
      printf '%s\t%s\t%s\n' "$name" "$image" "$status"
    fi
  done
}

find_devcontainer_container() {
  local containers count
  containers="$(project_containers)"
  [[ -n "$containers" ]] || return 0

  count="$(printf '%s\n' "$containers" | wc -l)"
  if [[ "$count" -eq 1 ]]; then
    printf '%s\n' "$containers" | cut -f1
    return 0
  fi

  choose_container "$containers"
}

ensure_devcontainer_running() {
  # Devcontainers CLI auto-mounts the Wayland socket when WAYLAND_DISPLAY is
  # set.  Docker refuses to start the container if the source path is missing
  # or is a regular file — it must be a real Unix socket.  Ensure one exists.
  if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    local wayland_socket="/run/user/$(id -u)/$WAYLAND_DISPLAY"
    if [[ -e "$wayland_socket" && ! -S "$wayland_socket" ]]; then
      rm -f "$wayland_socket"
    fi
    if [[ ! -e "$wayland_socket" ]]; then
      python3 -c "
import socket, os
p = '$wayland_socket'
try:
    os.unlink(p)
except FileNotFoundError:
    pass
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.bind(p)
s.listen(0)
" &
    fi
  fi

  local container=""
  container="$(find_devcontainer_container)"
  if [[ -n "$container" ]]; then
    if ! docker ps --format '{{.Names}}' | grep -Fxq "$container"; then
      step "starting existing devcontainer" "$container"
      docker start "$container" 2>&1 | tee "$startup_log_host" >&2
      run_post_start_command "$container"
    fi
    printf '%s\n' "$container"
    return 0
  fi

  step "creating devcontainer" "$root"
  local dc_cmd
  dc_cmd="$(devcontainer_cmd)"
  eval "$dc_cmd" up --workspace-folder "$(quote "$root")" 2>&1 | tee "$startup_log_host" >&2

  container="$(find_devcontainer_container)"
  [[ -n "$container" ]] || die "devcontainer started, but no matching running container was found"
  printf '%s\n' "$container"
}

run_post_start_command() {
  local container="$1" post_start remote_user workspace
  post_start="$(devcontainer_json_value postStartCommand || true)"
  [[ -n "$post_start" ]] || return 0

  remote_user="$(devcontainer_json_value remoteUser || true)"
  [[ -n "$remote_user" ]] || remote_user="$(docker inspect -f '{{.Config.User}}' "$container" 2>/dev/null || true)"
  [[ -n "$remote_user" ]] || remote_user=root

  workspace="$(container_workspace "$container")"
  step "postStartCommand" "devcontainer.json"
  docker exec -u "$remote_user" -w "$workspace" "$container" sh -lc "$post_start" 2>&1 | tee -a "$startup_log_host" >&2
}

copy_startup_log_to_container() {
  local container="$1" root_name remote_log
  root_name="$(basename "$root")"
  remote_log="/tmp/nvim-dev-$root_name-startup.log"

  [[ -s "$startup_log_host" ]] || return 0
  docker cp "$startup_log_host" "$container:$remote_log" >/dev/null 2>&1 || return 0
}

bootstrap_and_start_server() {
  local container="$1" workspace="$2" port="$3" root_name
  root_name="$(basename "$root")"

  local host_state_file="${XDG_STATE_HOME:-$HOME/.local/state}/nvim/clangd_build_dirs.json"
  local host_build_dir=""
  local remote_build_dir=""
  if [[ -f "$host_state_file" ]]; then
    host_build_dir="$(python3 - "$host_state_file" "$root" <<'PY' 2>/dev/null || true
import json, sys
try:
    data = json.load(open(sys.argv[1], 'r', encoding='utf-8'))
    print(data.get(sys.argv[2], ''))
except Exception:
    pass
PY
)"
  fi
  if [[ -n "$host_build_dir" ]]; then
    case "$host_build_dir" in
      "$root"/*) remote_build_dir="$workspace/${host_build_dir#"$root"/}" ;;
    esac
  fi

  local script
  script="set -e
export DEVCONTAINER=true
export NVIM_DEV_HOST_ROOT=$(quote "$root")
export NVIM_DEV_CONTAINER_WORKSPACE=$(quote "$workspace")
export OPENCODE_SERVER_URL=$(quote "${OPENCODE_SERVER_URL:-http://127.0.0.1:4096}")
if [ -n $(quote "$remote_build_dir") ] && [ -f $(quote "$remote_build_dir/compile_commands.json") ]; then
  export NVIM_CLANGD_COMPILE_COMMANDS_DIR=$(quote "$remote_build_dir")
fi
if ! command -v nvim >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then SUDO=sudo; else SUDO=; fi
    \$SUDO apt-get update || true
    \$SUDO apt-get install -y software-properties-common curl git ripgrep fd-find python3 python3-pip nodejs npm || true
    \$SUDO add-apt-repository -y ppa:neovim-ppa/unstable >/dev/null 2>&1 || true
    \$SUDO apt-get update || true
    \$SUDO apt-get install -y neovim || true
  elif command -v apk >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then sudo apk add --no-cache neovim git ripgrep fd python3 nodejs npm; else apk add --no-cache neovim git ripgrep fd python3 nodejs npm; fi
  elif command -v dnf >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then sudo dnf install -y neovim git ripgrep fd-find python3 nodejs npm; else dnf install -y neovim git ripgrep fd-find python3 nodejs npm; fi
  fi
fi
command -v nvim >/dev/null 2>&1 || { echo 'nvim is not installed in this container' >&2; exit 127; }
mkdir -p \"\${XDG_CONFIG_HOME:-\$HOME/.config}\"
config_dir="\${XDG_CONFIG_HOME:-\$HOME/.config}/nvim"
data_dir="\${XDG_DATA_HOME:-\$HOME/.local/share}/nvim"
state_dir="\${XDG_STATE_HOME:-\$HOME/.local/state}/nvim"
mkdir -p "\$data_dir" "\$state_dir"
lock_file="\$config_dir/lazy-lock.json"
hash_file="\$state_dir/nvim-dev-lazy-lock.sha256"
current_hash_file="\$state_dir/nvim-dev-lazy-lock.current.sha256"
if [ -f "\$lock_file" ] && command -v sha256sum >/dev/null 2>&1; then
  sha256sum "\$lock_file" > "\$current_hash_file"
fi
if [ "\${NVIM_DEV_SYNC_PLUGINS:-auto}" = always ] || [ ! -d "\$data_dir/lazy/lazy.nvim" ] || { [ -f "\$current_hash_file" ] && ! cmp -s "\$current_hash_file" "\$hash_file"; }; then
  nvim --headless '+Lazy! sync' '+qa' || true
  if [ -f "\$current_hash_file" ]; then mv "\$current_hash_file" "\$hash_file"; fi
fi
workspace=$(quote "$workspace")
if [ ! -d \"\$workspace\" ]; then workspace=/workspaces/$(quote "$root_name"); fi
if [ ! -d \"\$workspace\" ]; then workspace=/workspace/$(quote "$root_name"); fi
if [ ! -d \"\$workspace\" ]; then workspace=\$PWD; fi
cd \"\$workspace\"
printf '%s\n' $(quote "$port") > /tmp/$(quote "nvim-dev-$root_name.port")
exec nvim --listen 0.0.0.0:$port --headless"

  docker exec -d "$container" sh -lc "$script" >/dev/null
}

running_server_port() {
  local container="$1" root_name
  root_name="$(basename "$root")"

  docker exec "$container" sh -lc "
file=/tmp/$(quote "nvim-dev-$root_name.port")
[ -f \"\$file\" ] || exit 0
port=\$(cat \"\$file\" 2>/dev/null || true)
case \"\$port\" in ''|*[!0-9]*) exit 0 ;; esac
if command -v timeout >/dev/null 2>&1; then
  timeout 2s nvim --server 127.0.0.1:\$port --remote-expr 1 >/dev/null 2>&1
else
  nvim --server 127.0.0.1:\$port --remote-expr 1 >/dev/null 2>&1
fi
if [ \$? -eq 0 ]; then
  printf '%s\n' \"\$port\"
fi
" 2>/dev/null || true
}

sync_nvim_config_to_container() {
  local container="$1" start config_hash remote_hash
  start=$SECONDS
  step "sync config" "host → container"

  if [[ ! -d "$HOME/.config/nvim" ]]; then
    die "host nvim config not found at $HOME/.config/nvim"
  fi

  config_hash="$(tar --sort=name --mtime='UTC 1970-01-01' --owner=0 --group=0 --numeric-owner --exclude=nvim/.git -C "$HOME/.config" -cf - nvim | sha256sum | cut -d ' ' -f 1)"

  IFS='|' read -r user_id group_id config_dir remote_hash < <(
    docker exec "$container" sh -lc '
      uid=$(id -u)
      gid=$(id -g)
      cfg="${XDG_CONFIG_HOME:-$HOME/.config}"
      rh=$(cat "$cfg/.nvim-config.sha256" 2>/dev/null || true)
      printf "%s|%s|%s|%s\n" "$uid" "$gid" "$cfg" "$rh"
    '
  ) || die "failed to read container metadata"

  if [[ -n "$config_hash" && "$config_hash" == "$remote_hash" ]]; then
    ok "config unchanged" "$((SECONDS - start))s"
    return 0
  fi

  docker exec -u root "$container" sh -lc "
    rm -rf $(quote "$config_dir/nvim") && mkdir -p $(quote "$config_dir")
  " || die "failed to prepare container nvim config dir"
  tar --exclude=nvim/.git -C "$HOME/.config" -cf - nvim \
    | docker exec -i -u root "$container" sh -lc "tar -C $(quote "$config_dir") -xf -" \
    || die "failed to sync nvim config to container"
  docker exec -u root "$container" sh -lc "
    printf '%s\n' $(quote "$config_hash") > $(quote "$config_dir/.nvim-config.sha256")
    mkdir -p $(quote "$config_dir/clangd")
    chown -R $(quote "$user_id:$group_id") $(quote "$config_dir/nvim") $(quote "$config_dir/clangd") $(quote "$config_dir/.nvim-config.sha256")
  " || true
  printf '%s\n' "$config_hash" > "$HOME/.config/nvim/.nvim-config.sha256"
  ok "config synced" "$((SECONDS - start))s"
}

ensure_container_tools() {
  local container="$1" start config_hash check_out
  start=$SECONDS
  step "check tools" "nvim git rg fzf clang-format lazygit PyYAML"

  config_hash="$(tar --sort=name --mtime='UTC 1970-01-01' --owner=0 --group=0 --numeric-owner --exclude=nvim/.git -C "$HOME/.config" -cf - nvim 2>/dev/null | sha256sum | cut -d ' ' -f 1 || true)"

  check_out="$(docker exec "$container" sh -lc "
    set -e
    cfg=\"\${XDG_CONFIG_HOME:-\$HOME/.config}\"
    tag_file=\"\$cfg/nvim/.nvim-tools.ok\"
    if [ -f \"\$tag_file\" ] && [ \"\$(cat \"\$tag_file\" 2>/dev/null || true)\" = $(quote "$config_hash") ]; then
      printf '%s\n' cached
    else
      printf '%s\n' \"\$cfg\"
    fi
  " 2>/dev/null || true)"

  if [[ "$check_out" == "cached" ]]; then
    ok "tools ready" "$((SECONDS - start))s"
    return 0
  fi
  local config_dir="$check_out"

  docker exec -u root "$container" sh -lc '
set -e
for cmd in nvim git rg fzf curl tar clang-format lazygit; do
  command -v "$cmd" >/dev/null 2>&1 || { missing=1; break; }
done
python3 - <<'PY' >/dev/null 2>&1 || missing=1
import yaml
PY
if [ -n "${missing:-}" ]; then
  if command -v apt-get >/dev/null 2>&1; then
    rm -f /etc/apt/sources.list.d/lazygit-team-ubuntu-release-*.list /etc/apt/sources.list.d/lazygit-team-ubuntu-release-*.sources
    apt-get update
    apt-get install -y software-properties-common curl git ripgrep fd-find fzf tar python3 python3-pip python3-yaml clang-format
    if ! command -v lazygit >/dev/null 2>&1; then
      arch="$(uname -m)"
      case "$arch" in
        x86_64|amd64) asset_arch=x86_64 ;;
        aarch64|arm64) asset_arch=arm64 ;;
        *) asset_arch= ;;
      esac
      if [ -n "$asset_arch" ]; then
        version="$(python3 -c "import json, urllib.request; r=urllib.request.urlopen(\"https://api.github.com/repos/jesseduffield/lazygit/releases/latest\", timeout=20); print(json.load(r).get(\"tag_name\", \"\").lstrip(\"v\"))")"
        tmp="$(mktemp -d)"
        curl -fsSL -o "$tmp/lazygit.tar.gz" "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${version}_Linux_${asset_arch}.tar.gz"
        tar -C "$tmp" -xf "$tmp/lazygit.tar.gz" lazygit
        install -m 0755 "$tmp/lazygit" /usr/local/bin/lazygit
        rm -rf "$tmp"
      fi
    fi
    if ! command -v nvim >/dev/null 2>&1; then
      add-apt-repository -y ppa:neovim-ppa/unstable >/dev/null 2>&1 || true
      apt-get update
      apt-get install -y neovim
    fi
  elif command -v apk >/dev/null 2>&1; then
    apk add --no-cache neovim git ripgrep fd fzf curl tar python3 py3-yaml nodejs npm clang-extra-tools || true
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y neovim git ripgrep fd-find fzf curl tar python3 python3-pyyaml nodejs npm clang-tools-extra || true
  fi
fi
' || die "failed to ensure required tools in container"

  if [[ -n "$config_hash" && -n "$config_dir" ]]; then
    docker exec -u root "$container" sh -lc "
      mkdir -p $config_dir/nvim
      printf '%s\n' $(quote "$config_hash") > $config_dir/nvim/.nvim-tools.ok
    " 2>/dev/null || true
  fi
  ok "tools ready" "$((SECONDS - start))s"
}

wait_for_server() {
  local addr="$1"
  local i spin elapsed
  local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  for i in $(seq 1 100); do
    if nvim_remote_expr "$addr" 1; then
      if [[ -t 2 ]]; then
        printf '\r\033[K' >&2
      fi
      ok "server online" "$addr"
      return 0
    fi
    if [[ -t 2 ]]; then
      spin="${frames[$(((i - 1) % ${#frames[@]}))]}"
      elapsed=$((i / 10))
      printf '\r%b %bwaiting for nvim server%b %s %bs%b' "${c_yellow}${spin}${c_reset}" "${c_bold}" "${c_reset}" "$addr" "${c_dim}${elapsed}" "${c_reset}" >&2
    fi
    sleep 0.1
  done
  if [[ -t 2 ]]; then
    printf '\r\033[K' >&2
  fi
  return 1
}

need docker
install_host_wrappers
nvim_bin="$(real_nvim)" || die "real nvim binary not found"
banner

root="$(project_root)"
if ! has_devcontainer; then
  info "no devcontainer found" "opening local nvim"
  exec "$nvim_bin" "$root"
fi

root_name="$(basename "$root")"
startup_log_host="${XDG_STATE_HOME:-$HOME/.local/state}/nvim/nvim-dev-$root_name-startup.log"
mkdir -p "$(dirname "$startup_log_host")"
rm -f "$startup_log_host"

action="${NVIM_DEV_ACTION:-attach}"
container="${NVIM_DEV_CONTAINER:-}"

case "$action" in
  attach)
    container="${container:-$(ensure_devcontainer_running)}"
    ;;
  up|reopen)
    dc_cmd="$(devcontainer_cmd)"
    eval "$dc_cmd" up --workspace-folder "$(quote "$root")" 2>&1 | tee "$startup_log_host"
    container="${container:-$(find_devcontainer_container)}"
    [[ -n "$container" ]] || container="$(choose_container)"
    ;;
  rebuild)
    dc_cmd="$(devcontainer_cmd)"
    eval "$dc_cmd" up --workspace-folder "$(quote "$root")" --remove-existing-container 2>&1 | tee "$startup_log_host"
    container="${container:-$(find_devcontainer_container)}"
    [[ -n "$container" ]] || container="$(choose_container)"
    ;;
  *)
    die "unknown NVIM_DEV_ACTION: $action"
    ;;
esac

workspace="$(container_workspace "$container")"
host="$(container_host "$container")"
existing_port="$(running_server_port "$container")"
port="${NVIM_DEV_PORT:-$existing_port}"
if [[ -z "$port" ]]; then
  port="$((41000 + RANDOM % 10000))"
fi
addr="$host:$port"

sync_nvim_config_to_container "$container"
ensure_container_tools "$container"
copy_startup_log_to_container "$container"

info "container" "$container"
info "workspace" "$workspace"
info "server" "$addr"
if [[ -n "$existing_port" && "$existing_port" == "$port" ]]; then
  ok "reuse server" "$addr"
else
  step "start server" "$addr"
  bootstrap_and_start_server "$container" "$workspace" "$port"
fi
wait_for_server "$addr" || die "timed out waiting for container nvim server at $addr"
ok "attach remote UI"

exec "$nvim_bin" --server "$addr" --remote-ui
