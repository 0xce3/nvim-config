#!/usr/bin/env bash
set -euo pipefail

repo_url="${NVIM_CONFIG_REPO:-https://github.com/0xce3/nvim-config.git}"
target="${1:-.}"

log() { printf '%s\n' "$*" >&2; }
die() { log "nvim-dev: $*"; exit 1; }

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

devcontainer_cmd() {
  if command -v devcontainer >/dev/null 2>&1; then
    printf 'devcontainer\n'
  elif command -v npx >/dev/null 2>&1; then
    printf 'npx -y @devcontainers/cli\n'
  else
    die "missing devcontainer CLI; install with: npm install -g @devcontainers/cli"
  fi
}

quote() {
  printf '%q' "$1"
}

project_root() {
  local dir
  dir="$(cd "$target" 2>/dev/null && pwd -P)" || die "not a directory: $target"
  while [[ "$dir" != / ]]; do
    if [[ -f "$dir/.devcontainer/devcontainer.json" || -f "$dir/devcontainer.json" || -d "$dir/.git" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  cd "$target" && pwd -P
}

has_devcontainer() {
  [[ -f "$root/.devcontainer/devcontainer.json" || -f "$root/devcontainer.json" ]]
}

container_workspace() {
  local container="$1"
  local root_name
  root_name="$(basename "$root")"

  local label_ws
  label_ws="$(docker inspect -f '{{ index .Config.Labels "devcontainer.workspace_folder" }}' "$container" 2>/dev/null || true)"
  if [[ -n "$label_ws" && "$label_ws" != "<no value>" ]]; then
    printf '%s\n' "$label_ws"
    return 0
  fi

  local mount_dest
  mount_dest="$(docker inspect -f '{{ range .Mounts }}{{ if eq .Source "'"$root"'" }}{{ .Destination }}{{ end }}{{ end }}' "$container" 2>/dev/null || true)"
  if [[ -n "$mount_dest" ]]; then
    printf '%s\n' "$mount_dest"
    return 0
  fi

  printf '/workspaces/%s\n' "$root_name"
}

container_host() {
  local container="$1"
  local network_json
  network_json="$(docker inspect -f '{{json .NetworkSettings.Networks}}' "$container")"
  if printf '%s' "$network_json" | grep -q '"host"'; then
    printf '127.0.0.1\n'
    return 0
  fi
  local ip
  ip="$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$container")"
  [[ -n "$ip" ]] || die "could not determine container IP for $container"
  printf '%s\n' "$ip"
}

choose_container() {
  local containers
  containers="$(docker ps --format '{{.Names}}\t{{.Image}}\t{{.Status}}')"
  [[ -n "$containers" ]] || die "no running containers"

  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$containers" | fzf --prompt='Attach container> ' | cut -f1
    return 0
  fi

  log "Running containers:"
  local i=0 names=()
  while IFS=$'\t' read -r name image status; do
    i=$((i + 1))
    names+=("$name")
    log "  $i) $name  $image  $status"
  done <<< "$containers"
  printf 'Select container: ' >&2
  local choice
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid selection"
  printf '%s\n' "${names[$((choice - 1))]}"
}

find_devcontainer_container() {
  local root_name image_name mounted
  root_name="$(basename "$root")"
  image_name="vsc-${root_name//-/_}"

  mounted="$(docker ps --format '{{.Names}}' | while read -r name; do
    docker inspect -f '{{ range .Mounts }}{{ .Source }} {{ end }}' "$name" 2>/dev/null | grep -Fq "$root" && printf '%s\n' "$name"
  done | head -n1)"
  if [[ -n "$mounted" ]]; then
    printf '%s\n' "$mounted"
    return 0
  fi

  docker ps --format '{{.Names}}\t{{.Image}}' | awk -F '\t' -v image="$image_name" 'index($2, image) == 1 { print $1; exit }'
}

bootstrap_and_start_server() {
  local container="$1" workspace="$2" port="$3" root_name
  root_name="$(basename "$root")"

  local script
  script="set -e
export DEVCONTAINER=true
if ! command -v nvim >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then SUDO=sudo; else SUDO=; fi
    \$SUDO apt-get update || true
    \$SUDO apt-get install -y software-properties-common curl git ripgrep fd-find python3 python3-pip nodejs npm || true
    \$SUDO add-apt-repository -y ppa:neovim-ppa/unstable >/dev/null 2>&1 || true
    \$SUDO apt-get update || true
    \$SUDO apt-get install -y neovim || true
  elif command -v apk >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then sudo apk add --no-cache neovim git ripgrep fd python3 nodejs npm; else apk add --no-cache neovim git ripgrep fd python3 nodejs npm; fi
  elif command -v dnf >/dev/null 2>&1; then
    if command -v sudo >/dev/null 2>&1; then sudo dnf install -y neovim git ripgrep fd-find python3 nodejs npm; else dnf install -y neovim git ripgrep fd-find python3 nodejs npm; fi
  fi
fi
command -v nvim >/dev/null 2>&1 || { echo 'nvim is not installed in this container' >&2; exit 127; }
mkdir -p \"\${XDG_CONFIG_HOME:-\$HOME/.config}\"
if [ -d \"\${XDG_CONFIG_HOME:-\$HOME/.config}/nvim/.git\" ]; then
  git -C \"\${XDG_CONFIG_HOME:-\$HOME/.config}/nvim\" pull --ff-only || true
else
  rm -rf \"\${XDG_CONFIG_HOME:-\$HOME/.config}/nvim\"
  git clone $(quote "$repo_url") \"\${XDG_CONFIG_HOME:-\$HOME/.config}/nvim\"
fi
nvim --headless '+Lazy! sync' '+qa' || true
workspace=$(quote "$workspace")
if [ ! -d \"\$workspace\" ]; then workspace=/workspaces/$(quote "$root_name"); fi
if [ ! -d \"\$workspace\" ]; then workspace=/workspace/$(quote "$root_name"); fi
if [ ! -d \"\$workspace\" ]; then workspace=\$PWD; fi
cd \"\$workspace\"
exec nvim --listen 0.0.0.0:$port --headless"

  docker exec -d "$container" sh -lc "$script" >/dev/null
}

wait_for_server() {
  local addr="$1"
  local i
  for i in $(seq 1 100); do
    if nvim --server "$addr" --remote-expr 1 >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

need docker
need nvim

root="$(project_root)"
if ! has_devcontainer; then
  exec nvim "$root"
fi

action="${NVIM_DEV_ACTION:-attach}"
container="${NVIM_DEV_CONTAINER:-}"

case "$action" in
  attach)
    container="${container:-$(find_devcontainer_container)}"
    if [[ -z "$container" ]]; then
      container="$(choose_container)"
    fi
    ;;
  up|reopen)
    dc_cmd="$(devcontainer_cmd)"
    eval "$dc_cmd" up --workspace-folder "$(quote "$root")"
    container="${container:-$(find_devcontainer_container)}"
    [[ -n "$container" ]] || container="$(choose_container)"
    ;;
  rebuild)
    dc_cmd="$(devcontainer_cmd)"
    eval "$dc_cmd" up --workspace-folder "$(quote "$root")" --remove-existing-container
    container="${container:-$(find_devcontainer_container)}"
    [[ -n "$container" ]] || container="$(choose_container)"
    ;;
  *)
    die "unknown NVIM_DEV_ACTION: $action"
    ;;
esac

workspace="$(container_workspace "$container")"
host="$(container_host "$container")"
port="${NVIM_DEV_PORT:-$((41000 + RANDOM % 10000))}"
addr="$host:$port"

log "nvim-dev: container=$container workspace=$workspace addr=$addr"
bootstrap_and_start_server "$container" "$workspace" "$port"
wait_for_server "$addr" || die "timed out waiting for container nvim server at $addr"

exec nvim --server "$addr" --remote-ui
